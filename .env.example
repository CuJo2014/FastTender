# Скопируйте в .env при необходимости override (docker-compose сам выставляет дефолты).
# Все переменные имеют префикс FT_.

FT_ENVIRONMENT=dev
FT_DEBUG=true

FT_DATABASE_URL=postgresql+asyncpg://fasttender:fasttender@localhost:5432/fasttender
FT_DATABASE_URL_SYNC=postgresql+psycopg://fasttender:fasttender@localhost:5432/fasttender
FT_REDIS_URL=redis://localhost:6379/0

FT_UPLOAD_DIR=./uploads
FT_MAX_UPLOAD_SIZE_MB=50

# Пороги уверенности матчера (раздел 4.5, 6.1 A3)
FT_CONFIDENCE_AUTO_CONFIRM=0.9
FT_CONFIDENCE_MIN=0.5

FT_CORS_ORIGINS=["http://localhost:5173"]
