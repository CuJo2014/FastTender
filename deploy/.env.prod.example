# Production environment для FastTender.
# Скопируй в .env.prod и заполни. Никогда не коммить .env.prod в git.

# --- Публичный hostname ---
# A-запись DNS должна указывать на IP этого сервера ДО первого запуска
# (иначе Let's Encrypt не выдаст сертификат).
DOMAIN=fasttender.example.com

# Email для уведомлений Let's Encrypt (об истечении серта и т.п.)
CADDY_EMAIL=admin@example.com

# --- Basic Auth (раздел 5.3) ---
# Логин в открытом виде, bcrypt-хеш пароля.
# Генерация: deploy/bootstrap.sh basic-auth (выводит уже эскейпленный хеш)
# Или вручную: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'СЕКРЕТ'
#
# ВАЖНО: docker-compose --env-file интерпретирует ${...} в значениях,
# поэтому каждый `$` в bcrypt-хеше нужно УДВОИТЬ → `$$`.
#   было  : $2a$14$abcd...
#   стало : $$2a$$14$$abcd...
# Иначе compose будет ругаться на "variable not set" и хеш разломается.
BASIC_AUTH_USER=fasttender
BASIC_AUTH_HASH=$$2a$$14$$ЗАМЕНИ_МЕНЯ_НА_РЕАЛЬНЫЙ_BCRYPT_ХЕШ
# Второй пользователь (опционально). Если заполняешь — нужны ОБЕ строки,
# иначе пустая пара логин/хеш ломает парсинг Caddyfile. Хеш так же с `$$`.
# BASIC_AUTH_USER2=ivanov_ii
# BASIC_AUTH_HASH2=$$2a$$14$$ЗАМЕНИ_МЕНЯ

# --- PostgreSQL ---
# ПОМЕНЯЙ дефолтный пароль на сильный.
POSTGRES_USER=fasttender
POSTGRES_PASSWORD=ЗАМЕНИ_МЕНЯ_СИЛЬНЫЙ_ПАРОЛЬ
POSTGRES_DB=fasttender

# --- Лимиты приложения ---
FT_MAX_UPLOAD_SIZE_MB=50

# --- Параллелизм (тюнинг под VPS ресурсы) ---
UVICORN_WORKERS=2
CELERY_CONCURRENCY=2
